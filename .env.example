# ──────────────────── OKX Credentials ─────────────────────────────
# Get these from: https://www.okx.com/account/my-api  (live)
# Or: https://www.okx.com/account/my-api?mode=demo    (demo trading)
# Demo trading also has its own login at https://www.okx.com/trade-demo
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# OKX_FLAG: "0" = live trading, "1" = demo trading (paper money)
# Default = "1" so you can test safely. Set to "0" only when ready for live.
OKX_FLAG=1

# OKX regional endpoint (keys are scoped per-region):
#   https://www.okx.com   — global (default)
#   https://my.okx.com    — OKX Singapore (use this if you log in via my.okx.com/en-sg/)
#   https://app.okx.com   — alt regional gateway
# Mismatch returns 50119 "API key doesn't exist".
OKX_DOMAIN=https://www.okx.com

# DRY_RUN: "true" simulates orders without sending to OKX
# Recommended for first run: keep DRY_RUN=true to verify everything is wired
# correctly. Then DRY_RUN=false (still on demo) to actually place demo orders.
DRY_RUN=true

# ──────────────────── Strategy ────────────────────────────────────
# Quantity model for OKX BTC-USD inverse options:
#   • You set qty_per_leg in BTC NOTIONAL (e.g. 0.5 = half a BTC of underlying)
#   • OKX trades in CONTRACTS (integer count). 1 contract = 0.01 BTC underlying
#     for BTC-USD options (verified empirically: pos=50 contracts shows as
#     0.5 BTC notional in the OKX UI).
#   • The algo converts: contracts = qty_per_leg / OKX_CONTRACT_SIZE_BTC
#     so 0.5 BTC with OKX_CONTRACT_SIZE_BTC=0.01 → 50 contracts.
#
# DO NOT change OKX_CONTRACT_SIZE_BTC away from 0.01 unless OKX changes their
# inverse-option spec. The /api/v5/public/instruments endpoint reports
# ctVal=1.0 for these instruments — IGNORE that, it's a USD multiplier on
# inverse contracts, not the BTC notional we use here.

# ── 4-session schedule (20 trades / week) ──
# Sessions are named by their UTC entry time (utc_HHMM) so the schedule is
# unambiguous across timezones. All four sessions target the SAME 08:00 UTC
# expiry of the same trading day and aggregate into one daily P&L.
#
#   utc_0900  →  09:00-09:30 UTC  Mon-Fri  ~23h to expiry (1st of trading day)
#   utc_1330  →  13:30-15:30 UTC  Mon-Fri  ~18h to expiry (2nd of trading day)
#   utc_2330  →  23:30-24:00 UTC  Mon-Fri  ~8h  to expiry (3rd; close at next-day 00:00 UTC)
#   utc_0100  →  01:00-02:00 UTC  Tue-Sat  ~7h  to expiry (4th = LAST close → triggers daily report)
#
# Each session has FOUR per-session env knobs:
#
#   <NAME>_SIZING       "fixed_btc" or "pct_equity"
#                       (default: pct_equity for all four sessions)
#   <NAME>_PCT_EQUITY   target premium as a fraction of current equity,
#                       used iff SIZING=pct_equity. Maps to "premium paid
#                       as a % of equity" — i.e. % of equity at risk per entry.
#   <NAME>_QTY_PER_LEG  fixed BTC qty/leg, used iff SIZING=fixed_btc, also
#                       the FALLBACK qty if pct_equity sizing fails (zero
#                       equity, missing marks). 0.5 BTC is conservative.
#   <NAME>_ENABLED      "true" / "false" / "1" / "0" / "yes" / "no" / "off"
#                       (default: true). Set to "false" to surgically remove
#                       a session from the scheduler WITHOUT a code change.
#                       Disabled sessions: no entry/close cron registered,
#                       excluded from chase-deadline validator, ignored by
#                       ENTRY_NOW=true (which falls through to the next
#                       enabled session). Other knobs still parse so the
#                       session can be re-enabled instantly.
#
# OPERATOR PANIC-BUTTON: <NAME>_ENABLED=false is the safest soft-rollback
# tool. If a session misbehaves, set its ENABLED=false in .env and restart
# — all other sessions keep firing on schedule, and you can reactivate
# without touching code.
#
# Defaults — operator-confirmed plan as of 2026-05-20:
#   • utc_0900 / utc_2330  →  pct_equity=0.25 (25% premium budget per entry)
#   • utc_1330 / utc_0100  →  pct_equity=0.50 (50% premium budget per entry)
#   • all four sessions ENABLED
UTC_0900_SIZING=pct_equity
UTC_0900_PCT_EQUITY=0.25
UTC_0900_QTY_PER_LEG=0.5
UTC_0900_ENABLED=true

UTC_1330_SIZING=pct_equity
UTC_1330_PCT_EQUITY=0.50
UTC_1330_QTY_PER_LEG=0.5
UTC_1330_ENABLED=true

UTC_2330_SIZING=pct_equity
UTC_2330_PCT_EQUITY=0.25
UTC_2330_QTY_PER_LEG=0.5
UTC_2330_ENABLED=true

UTC_0100_SIZING=pct_equity
UTC_0100_PCT_EQUITY=0.50
UTC_0100_QTY_PER_LEG=0.25
UTC_0100_ENABLED=true

# Hard sanity guards on per-leg qty (BTC). The pct_equity math at current
# equity (~$7,761) and current vol (~$1,360 USD per 1 BTC straddle) sizes a
# 50% session at ~2.85 BTC. The default 5.0 BTC cap leaves ~75% equity
# headroom before binding. Bump MAX_QTY_PER_LEG_BTC if equity grows past
# ~$13k AND you want to honour the configured pct_equity instead of capping.
# MIN_QTY_PER_LEG_BTC=0.01  (= 1 OKX contract; below this we skip the session)
MIN_QTY_PER_LEG_BTC=0.01
MAX_QTY_PER_LEG_BTC=5.0

# Legacy single-session knob — kept for older trade-log rows that pre-date
# the multi-session refactor. Not consumed by new entries.
QTY_PER_LEG=0.5

# OKX_CONTRACT_SIZE_BTC: BTC underlying per single OKX contract.
# FIXED at 0.01 for BTC-USD inverse options. Don't change.
OKX_CONTRACT_SIZE_BTC=0.01

# Underlying / quote currency. OKX BTC options are BTC-USD (coin-margined).
# Don't change unless you know what you're doing.
QUOTE_COIN=USD

# Equity bookkeeping starting point (used until live equity sync overrides)
INITIAL_CAPITAL_USD=8000

# Force exact straddle count regardless of capital (1 = always 1 straddle)
NUM_STRADDLES_OVERRIDE=1

# Fire an entry immediately on next start (auto-disabled after firing
# so a container restart never silently re-triggers entry).
#   • "false" / unset → no immediate entry, scheduler handles it
#   • "true"          → fires the FIRST ENABLED session in config.SESSIONS
#                       (currently utc_0900). If utc_0900 is disabled
#                       this falls through to the next enabled session.
#   • "utc_0900"      → fire the 09:00 UTC session immediately
#   • "utc_1330"      → fire the 13:30 UTC session immediately
#   • "utc_2330"      → fire the 23:30 UTC session immediately
#   • "utc_0100"      → fire the 01:00 UTC session immediately
#   • "morning"       → legacy alias for utc_0100 (still works)
#   • "afternoon"     → legacy alias for utc_1330 (still works)
#
# If the named session is DISABLED (<NAME>_ENABLED=false) the entry is
# REFUSED and a Telegram warning is sent — the disabled flag is treated
# as a stronger signal than ENTRY_NOW. Re-enable the session in .env
# first, then set ENTRY_NOW.
ENTRY_NOW=false

# Set RESET_STATE_ON_BOOT=true ONCE to wipe state/equity.json + state/positions.json
# at startup. Useful for cutting over from demo state to a clean live deployment
# (otherwise demo's $5,000 equity carries over). Auto-disables to false after
# running, same pattern as ENTRY_NOW.
RESET_STATE_ON_BOOT=false

# RFQ / Block trading — leave false unless your account has it enabled
USE_RFQ=false

# ──────────────────── Chase Logic ─────────────────────────────────
OPTION_CHASE_GAP_NARROW_PCT=0.5
OPTION_CHASE_MAX_SLIPPAGE_FACTOR=1.15

# Maker-chase deadlines: split per direction.
# Entry chase MUST finish within the session window. The shortest windows
# are utc_0900 (30 min) and utc_2330 (30 min). Setting this >30 risks
# completing entry AFTER the scheduled close, leaving the straddle without
# an unwind handler. 30.0 is the safe default; 25.0 leaves a buffer.
OPTION_ENTRY_CHASE_DEADLINE_MIN=25.0
# Exit chase is free to run past session close (no scheduler race), capped
# only by the 08:00 UTC option expiry. 120 min gives ample time to wait for
# the spread to collapse in dying 0DTE books.
OPTION_EXIT_CHASE_DEADLINE_MIN=120.0
# Legacy single-knob — if set, overrides BOTH of the above as a fallback.
# Leave commented unless you specifically need the old behaviour.
# OPTION_CHASE_DEADLINE_MIN=60.0

OPTION_MAX_ENTRY_SPREAD_PCT=0.30

# OKX BTC option tick size — auto-detected from
# /api/v5/public/instruments on startup. The env var below is only used
# as a transient fallback when the API is unreachable. LEAVE COMMENTED
# unless you have a specific reason — setting a wrong value here will
# only matter if OKX is down.
#
# Real values:
#   CM (BTC-USD)    : 0.0001 BTC
#   UM (BTC-USD_UM) : 5 USD
#
# OPTION_TICK_SIZE=0.0001    # CM only; uncomment as override
# OPTION_TICK_SIZE=5         # UM only; uncomment as override

# ──────────────────── Telegram (optional but recommended) ─────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORT_BOT_TOKEN=
TELEGRAM_REPORT_CHAT_ID=

# ──────────────────── Logging ─────────────────────────────────────
LOG_LEVEL=INFO
